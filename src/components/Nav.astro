---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}#menu`, label: 'Menu' },
  { href: `${base}#story`, label: 'Our Story' },
  { href: `${base}#gallery`, label: 'Gallery' },
  { href: `${base}#contact`, label: 'Find Us' },
];
---
<nav id="nav" style="position:fixed;top:0;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:1.3rem 4rem;background:rgba(250,248,244,.94);backdrop-filter:blur(16px);border-bottom:1px solid transparent;transition:border-color .25s,padding .25s">
  <a href={base} style="font-family:var(--font-serif);font-size:1.5rem;color:var(--espresso)">Brew &amp; Co.</a>
  <ul style="display:flex;gap:2rem;list-style:none">
    {links.map(l => (
      <li><a href={l.href} style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);transition:color .25s" class="nav-link">{l.label}</a></li>
    ))}
  </ul>
  <a href={`${base}#contact`} style="font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;background:var(--espresso);color:var(--warm);padding:.65rem 1.5rem;border-radius:var(--radius);transition:background .25s">Order &amp; Visit</a>
</nav>
<style>
  .nav-link:hover { color: var(--espresso) !important; }
  nav.scrolled { border-color: var(--border) !important; padding-top: .9rem !important; padding-bottom: .9rem !important; }
  @media(max-width:768px){ nav ul, nav > a:last-child { display:none !important; } nav { padding: 1rem 1.2rem !important; } }
</style>
<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 50), { passive: true });
</script>
