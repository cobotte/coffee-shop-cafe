---
import { Image } from 'astro:assets';
import heroCoffee from '../assets/images/hero_coffee.png';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<section style="min-height:100vh;display:flex;align-items:center;padding:0 4rem;background:linear-gradient(135deg,var(--cream),var(--sand));position:relative;overflow:hidden" id="home">
  <div style="position:absolute;right:0;top:0;bottom:0;width:45%;clip-path:polygon(12% 0,100% 0,100% 100%,0 100%);overflow:hidden" aria-hidden="true">
    <Image src={heroCoffee} alt="Specialty Coffee Pouring" style="width:100%;height:100%;object-fit:cover" />
  </div>
  <div style="position:relative;z-index:2;max-width:520px">
    <p style="font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--caramel);margin-bottom:1.5rem;display:flex;align-items:center;gap:.75rem">
      <span style="display:block;width:2rem;height:1px;background:var(--caramel)"></span>
      Est. 2017 · Specialty Coffee
    </p>
    <h1 style="font-family:var(--font-serif);font-size:clamp(3rem,5.5vw,5rem);font-weight:400;line-height:1.05;margin-bottom:1.5rem;color:var(--espresso)">
      Coffee, crafted<br />with <em style="font-style:italic;color:var(--caramel)">intention</em>
    </h1>
    <p style="font-size:.9rem;color:var(--brown);line-height:1.85;margin-bottom:2.5rem;max-width:380px">
      Single-origin beans, seasonal specials, and a space where slowing down feels natural. Come as you are.
    </p>
    <div style="display:flex;gap:1rem;flex-wrap:wrap">
      <a href={`${base}#menu`} style="background:var(--espresso);color:var(--warm);padding:.9rem 2rem;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;border-radius:var(--radius);transition:background .25s" onmouseover="this.style.background='var(--caramel)'" onmouseout="this.style.background='var(--espresso)'">View Menu</a>
      <a href={`${base}#contact`} style="color:var(--muted);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:.4rem;transition:color .25s" onmouseover="this.style.color='var(--espresso)'" onmouseout="this.style.color='var(--muted)'">Find Us →</a>
    </div>
    <div style="display:flex;gap:2.5rem;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border)">
      <div><div style="font-family:var(--font-serif);font-size:2rem;color:var(--espresso)">12+</div><div style="font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:.2rem">Origins</div></div>
      <div><div style="font-family:var(--font-serif);font-size:2rem;color:var(--espresso)">4.9</div><div style="font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:.2rem">Rating</div></div>
      <div><div style="font-family:var(--font-serif);font-size:2rem;color:var(--espresso)">7y</div><div style="font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:.2rem">In business</div></div>
    </div>
  </div>
</section>
