---
const drinks = [
  { name: 'Signature Flat White', desc: 'Double ristretto, micro-foam, single-origin Ethiopian', price: '£4.50', tag: 'Our Best' },
  { name: 'Oat Milk Cortado', desc: 'Perfectly balanced 1:1, cold-pressed oat milk', price: '£4.20', tag: '' },
  { name: 'Cold Brew Tonic', desc: '18-hour cold brew, fever-tree tonic, orange zest', price: '£5.00', tag: 'Seasonal' },
  { name: 'Matcha Latte', desc: 'Ceremonial grade, oat or almond milk, vanilla', price: '£4.80', tag: '' },
  { name: 'Pour Over (V60)', desc: 'Rotating single-origins, filter ground to order', price: '£5.50', tag: 'Specialty' },
  { name: 'House Chai', desc: 'House-spiced blend, steamed milk, cinnamon dust', price: '£4.20', tag: '' },
];
---
<section id="menu" style="padding:7rem 4rem;background:var(--cream)">
  <div class="reveal">
    <p style="font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--caramel);margin-bottom:1rem;display:flex;align-items:center;gap:.75rem"><span style="display:block;width:2rem;height:1px;background:var(--caramel)"></span>On the Bar</p>
    <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3rem);font-weight:400;line-height:1.2;margin-bottom:1rem;color:var(--espresso)">The Menu</h2>
    <p style="font-size:.85rem;color:var(--muted);line-height:1.85;max-width:480px;margin-bottom:3rem">Seasonal, single-origin, made with care. Our drinks menu changes regularly to reflect the best available from our roasters.</p>
  </div>
  <div class="reveal" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border)">
    {drinks.map(d => (
      <div style="background:var(--cream);padding:2.5rem;transition:background .25s;position:relative" onmouseover="this.style.background='var(--warm)'" onmouseout="this.style.background='var(--cream)'">
        {d.tag && <span style="position:absolute;top:1.5rem;right:1.5rem;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;background:var(--caramel);color:#fff;padding:.2rem .6rem;border-radius:100px">{d.tag}</span>}
        <div style="font-family:var(--font-serif);font-size:1.1rem;color:var(--espresso);margin-bottom:.5rem">{d.name}</div>
        <div style="font-size:.78rem;color:var(--muted);line-height:1.7;margin-bottom:1rem">{d.desc}</div>
        <div style="font-family:var(--font-serif);font-size:1.2rem;color:var(--caramel)">{d.price}</div>
      </div>
    ))}
  </div>
  <p style="font-size:.72rem;color:var(--muted);margin-top:1.5rem">All drinks available with oat, almond, soy, or full-fat milk. Ask our team about decaf options.</p>
</section>
<style>
  @media(max-width:768px){section{padding:4rem 1.2rem!important} div[style*="grid-template-columns"]{grid-template-columns:1fr!important}}
</style>
