---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import MenuHighlight from '../components/MenuHighlight.astro';
import Story from '../components/Story.astro';
import Gallery from '../components/Gallery.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Brew & Co — Specialty Coffee" description="A warm neighbourhood coffee shop with single-origin beans, seasonal drinks, and a welcoming space.">
  <Nav />
  <main id="main">
    <Hero />
    <MenuHighlight />
    <Story />
    <Gallery />
    <Contact />
  </main>
  <Footer />
</Layout>
